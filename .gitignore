# Unreal Engine generated directories
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# Xcode project files (auto-generated by UE)
*.xcworkspace/
*.xcodeproj/

# Visual Studio / Rider project files
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vs/

# VS Code settings (optional: remove if you want to share these)
.vscode/

# macOS
.DS_Store
**/.DS_Store

# Build artifacts
*.o
*.a
*.dylib
*.so
*.dll
*.pdb
*.exp
*.lib
*.ilk

# Unreal crash reports and logs
*.log
CrashReportClient/

# Unreal packaging output
Releases/
Packages/

# Content auto-generated files
Content/Collections/
Content/Developers/

# Large binary asset files (uncomment if using Git LFS instead)
# *.uasset
# *.umap

# UE shader cache
ShaderCache/

# UE automation tool
Automation/

# Unreal compiled C# files
Source/**/*.generated.cs
